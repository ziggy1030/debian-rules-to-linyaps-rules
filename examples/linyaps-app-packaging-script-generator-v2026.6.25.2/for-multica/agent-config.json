{
  "global": {
    "projects_root": "",
    "projects_repo": "",
    "output_dir": "./output/${tag}",
    "data_dir": "./data/${tag}.log",
    "build_tmp_dir": "./build_cache",
    "src_dir": "./src",
    "workspace": "linyaps"
  },
  "extension": [
    {
      "id": "arch_mapping",
      "description": "URL 架構關鍵字到 linyaps arch 的映射表，用於從下載 URL 中識別並轉換目標架構",
      "path": ""
    },
    {
      "id": "base_runtime_whitelist",
      "description": "玲瓏 base/runtime 全局白名單，定義所有已知合規的 base/runtime 組合，用於驗證和生成階段的組合檢查",
      "path": ""
    }
  ],
  "version_extract_examples": [
    {
      "description": "Firefox tar.xz release",
      "url_pattern": "firefox-{version}.en-US.linux-{arch}.tar.xz",
      "extract_regex": "firefox-([0-9]+\\.[0-9]+(?:\\.[0-9]+)*)\\.en-US"
    },
    {
      "description": "VS Code .deb package",
      "url_pattern": "code_{version}_{arch}.deb",
      "extract_regex": "code_([0-9]+\\.[0-9]+(?:\\.[0-9]+)*)_(?:amd64|arm64)\\.deb"
    },
    {
      "description": "Opera .deb package",
      "url_pattern": "opera-stable_{version}_{arch}.deb",
      "extract_regex": "opera-stable_([0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+)_(?:amd64|arm64)\\.deb"
    }
  ],
  "assignment": {
    "agents": [
      {
        "id": "upstream-tracker",
        "name": "上游版本追蹤智能體",
        "agent_file": null,
        "capabilities": ["upstream_tracking", "version_download", "resource_download"],
        "check_endpoint": null
      },
      {
        "id": "linyaps-packer-1",
        "name": "打包智能體",
        "agent_file": null,
        "capabilities": ["linyaps_packaging"],
        "check_endpoint": null
      },
      {
        "id": "linyaps-packer-2",
        "name": "打包智能體",
        "agent_file": null,
        "capabilities": ["linyaps_packaging"],
        "check_endpoint": null
      }
    ],
    "members": [
      {
        "id": "reviewer",
        "name": "審查人員",
        "role": "reviewer",
        "description": "人工審查打包腳本品質"
      }
    ],
    "default_strategy": {
      "project_not_found": {
        "handler": "mark-failed",
        "agent": null,
        "description": "技能管線執行過程中找不到 pkgName 對應的專案目錄 → 標記該任務失敗，當前 agent 即為專案初始化者，不應外派"
      },
      "skill_execution_failure": {
        "handler": "mark-failed",
        "agent": null,
        "description": "技能管線階段（deb-analysis / linglong-project-gen / resource-collector 等）執行失敗 → 直接標記該任務失敗，記錄失敗階段和錯誤資訊"
      },
      "build_failure": {
        "handler": "mark-failed",
        "agent": null,
        "description": "打包構建或驗證階段失敗 → 直接標記該任務失敗，不轉交給其他智能體重試"
      }
    }
  }
}
